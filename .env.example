# Resend email API key — get at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# OpenAI API key for GPT-4 personalization and intent parsing
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Groq API key (free — replaces OpenAI). Get at console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Secret token used to verify inbound Resend webhook signatures
WEBHOOK_SECRET=your_webhook_secret_here

# Optional: protect POST/GET /tasks with this header value (X-Webhook-Api-Key). Not used for /webhook (Resend).
WEBHOOK_API_KEY=

# Set to 1 or true to emit newline-delimited JSON logs to stdout
USE_JSON_LOGGING=

# SQLite database URL (default: local file)
DB_URL=sqlite:///./outreach.db

# Sender email address (must be verified on Resend with DKIM/SPF)
FROM_EMAIL=outreach@longevityintime.org

# Optional reply-to address for outbound emails
REPLY_TO_EMAIL=

# Optional IMAP inbox scanner for reply detection when not using Resend inbound webhooks
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# GPT model to use
OPENAI_MODEL=gpt-4o

# ── Preprint / arXiv ─────────────────────────────────────────────────────────
# arXiv account credentials for SWORD v2 submission
ARXIV_USERNAME=
ARXIV_PASSWORD=

# ── USPTO Patent Search ───────────────────────────────────────────────────────
# API key from https://data.uspto.gov/myodp/landing
USPTO_API_KEY=

# ── FDA ESG NextGen ───────────────────────────────────────────────────────────
# OAuth credentials from FDA Unified Submission Portal
FDA_CLIENT_ID=
FDA_CLIENT_SECRET=

# ── Telegram Integration ──────────────────────────────────────────────────────
# Bot token from @BotFather (e.g. 7234567890:AAEzXxxxxxx)
TELEGRAM_BOT_TOKEN=

# Channel ID for outreach alerts (get it by forwarding a channel message to @userinfobot)
TELEGRAM_ALERTS_CHANNEL_ID=

# Channel ID of the Telegram feed to monitor for signals (Rachel/Uhvat)
TELEGRAM_SOURCE_CHANNEL_ID=

# Your personal Telegram user ID
TELEGRAM_OWNER_ID=
